# Umgebungsvariablen fuer lokale Entwicklung
# Diese Datei wird NICHT committed (.env.local steht in .gitignore)
# In Production werden die Werte aus den Vercel-Umgebungsvariablen gelesen.

# Neon Serverless Postgres – Runtime (gepoolt, fuer App-Queries)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Neon Serverless Postgres – Migrationen (ungepoolt, fuer Schema-Aenderungen)
# Nur fuer Migrationsskripte noetig, nicht fuer die App-Runtime
DATABASE_URL_UNPOOLED=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Community Build-Einreichung aktivieren (default: false)
COMMUNITY_BUILDS_WRITE_ENABLED=false
